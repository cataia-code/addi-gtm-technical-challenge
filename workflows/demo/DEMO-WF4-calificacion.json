{
  "name": "DEMO-WF4: Calificacion con Groq",
  "nodes": [
    {
      "parameters": {
        "path": "classification-webhook",
        "responseMode": "onReceived",
        "responseData": "allEntries",
        "responseHeaders": {}
      },
      "id": "webhook_trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        250
      ]
    },
    {
      "parameters": {
        "jsCode": "const reply = $json.reply || 'Sin respuesta';\nconst systemPrompt = 'Classify merchant replies for Addi Marketplace and return only JSON with intent_score, is_decision_maker, objection_type, suggested_action, reasoning.';\nconst userMessage = `Reply del merchant: ${reply}\\n\\nContexto: merchant del sector Hogar con GMV anual de COP 4,908 MM.`;\nreturn { reply, systemPrompt, userMessage };"
      },
      "id": "code_prepare_prompt",
      "name": "Prepare Groq Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        250
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "headers": {
          "Authorization": "Bearer {{ $env.GROQ_API_KEY }}",
          "Content-Type": "application/json"
        },
        "body": {
          "model": "llama-3.3-70b-versatile",
          "messages": [
            {
              "role": "system",
              "content": "{{$json.systemPrompt}}"
            },
            {
              "role": "user",
              "content": "{{$json.userMessage}}"
            }
          ],
          "temperature": 0,
          "max_tokens": 200,
          "response_format": {
            "type": "json_object"
          }
        }
      },
      "id": "http_groq_api",
      "name": "Call Groq API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        750,
        250
      ]
    },
    {
      "parameters": {
        "jsCode": "const content = $json.choices?.[0]?.message?.content || '{}';\nconst parsed = JSON.parse(content);\nreturn [{ json: { reply: $json.reply || 'Sin respuesta', ...parsed, raw_response: content } }];"
      },
      "id": "code_parse_groq",
      "name": "Parse Groq Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        250
      ]
    }
  ],
  "connections": {
    "webhook_trigger": {
      "main": [
        [
          {
            "node": "code_prepare_prompt",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "code_prepare_prompt": {
      "main": [
        [
          {
            "node": "http_groq_api",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "http_groq_api": {
      "main": [
        [
          {
            "node": "code_parse_groq",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}
